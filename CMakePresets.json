{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "configurePresets": [
    {
      "hidden": true,
      "architecture": {
        "strategy": "external",
        "value": "x64"
      },
      "binaryDir": "${sourceDir}/bin/${presetName}",
      "generator": "Ninja",
      "name": "basePreset",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CARAREPORT_BUILD_SHARED": "OFF",
        "CARAREPORT_BUILD_TESTS": "OFF",
        "CARAREPORT_BUILD_EXAMPLE": "OFF"
      }
    },
    {
      "name": "x64 Debug",
      "inherits": "basePreset",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      },
      "description": "Debug build for x64"
    },
    {
      "name": "x64 Release",
      "inherits": "basePreset",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      },
      "description": "Release build for x64"
    },
    {
      "name": "x64 Debug Shared",
      "inherits": "x64 Debug",
      "cacheVariables": {
        "CARAREPORT_BUILD_SHARED": "ON"
      },
      "description": "Debug shared-library build for x64"
    },
    {
      "name": "x64 Release Shared",
      "inherits": "x64 Release",
      "cacheVariables": {
        "CARAREPORT_BUILD_SHARED": "ON"
      },
      "description": "Release shared-library build for x64"
    },
    {
      "name": "x64 Debug Tests",
      "inherits": "x64 Debug",
      "cacheVariables": {
        "CARAREPORT_BUILD_TESTS": "ON",
        "CARAREPORT_BUILD_EXAMPLE": "ON"
      },
      "description": "Debug build for x64 with tests enabled"
    }
  ],
  "buildPresets": [
    {
      "name": "x64 Debug",
      "configurePreset": "x64 Debug",
      "description": "Build the x64 Debug preset"
    },
    {
      "name": "x64 Release",
      "configurePreset": "x64 Release",
      "description": "Build the x64 Release preset"
    },
    {
      "name": "x64 Debug Shared",
      "configurePreset": "x64 Debug Shared",
      "description": "Build the x64 Debug Shared preset"
    },
    {
      "name": "x64 Release Shared",
      "configurePreset": "x64 Release Shared",
      "description": "Build the x64 Release Shared preset"
    },
    {
      "name": "x64 Debug Tests",
      "configurePreset": "x64 Debug Tests",
      "description": "Build the x64 Debug Tests preset"
    }
  ],
  "testPresets": [
    {
      "name": "x64 Debug Tests",
      "configurePreset": "x64 Debug Tests",
      "description": "Run tests for the x64 Debug Tests preset",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}